tests/cases/*/formal/*_buggy/
tests/cases/*/formal/adder_buggy/
tests/cases/*/formal/adder_fixed/
tests/cases/*/formal/adder_*.sby

# Case-local generated RTL caches. Recreate with the numbered prepare scripts.
tests/cases/*/formal/generated/

# UCAgent workspace caches and generated dynamic test reports.
tests/ucagent_workspaces/*/.ucagent/
tests/ucagent_workspaces/*/unity_test/
tests/ucagent_workspaces/*/uc_test_report/
tests/ucagent_workspaces/*/AGENTS.md
tests/ucagent_workspaces/*/Guide_Doc/
tests/ucagent_workspaces/*/reports/

