100: 
101:     def GetWaveFormat(self) -> str:
102:         """
103:         Get the waveform extension, or an empty string if disabled.
104: 
105:         Returns:
106:             str: The extension of waveform file.
107:         """
108:         return self.dut.GetWaveFormat()
109: 
110:     def FlushWaveform(self):
111:         self.dut.FlushWaveform()
112: 
113:     def SetCoverage(self, filename: str):
114:         self.dut.SetCoverage(filename)
115: 
116:     def GetCovMetrics(self) -> int:
117:         """
118:         Get the bitmask for collected coverage metrics. 0 means coverage is disabled
119: 
120:         Returns:
121:             int: Collected coverage metrics bitmask:
122:                 - Bit 0: line   (Line coverage)
123:                 - Bit 1: cond   (Condition coverage)
124:                 - Bit 2: fsm    (Finite-State Machine coverage)
125:                 - Bit 3: toggle (Toggle coverage)
126:                 - Bit 4: branch (Branch coverage)
127:                 - Bit 5: assert (Assertion coverage)
128:         """
129:         return self.dut.GetCovMetrics()
130:     
131:     def CheckPoint(self, name: str) -> int:
132:         self.dut.CheckPoint(name)
133: 
134:     def Restore(self, name: str) -> int:
135:         self.dut.Restore(name)
136: 
137:     def GetInternalSignal(self, name: str, index=-1, is_array=False, use_vpi=False):
138:         if name not in self.internal_signals:
139:             signal = None
140:             if self.dut.GetXSignalCFGBasePtr() != 0 and not use_vpi:
141:                 xname = "CFG:" + name
142:                 if is_array:
143:                     assert index < 0, "Index is not supported for array signal"
144:                     signal = self.xcfg.NewXDataArray(name, xname)
145:                 elif index >= 0:
146:                     signal = self.xcfg.NewXData(name, index, xname)
147:                 else:
148:                     signal = self.xcfg.NewXData(name, xname)
149:             else:
150:                 assert index < 0, "Index is not supported for VPI signal"
151:                 assert not is_array, "Array is not supported for VPI signal"
152:                 signal = xsp.XData.FromVPI(self.dut.GetVPIHandleObj(name),
153:                                            self.dut.GetVPIFuncPtr("vpi_get"),
154:                                            self.dut.GetVPIFuncPtr("vpi_get_value"),
155:                                            self.dut.GetVPIFuncPtr("vpi_put_value"), "VPI:" + name)
156:                 if use_vpi:
157:                     assert signal is not None, f"Internal signal {name} not found (Check VPI is enabled)"
158:             if signal is None:
159:                 return None
160:             if not isinstance(signal, xsp.XData):
161:                 self.internal_signals[name] = [xsp.XPin(s, self.event) for s in signal]
162:             else:
163:                 self.internal_signals[name] = xsp.XPin(signal, self.event)
164:         return self.internal_signals[name]
165: 
166:     def GetInternalSignalList(self, prefix="", deep=99, use_vpi=False):
167:         if self.dut.GetXSignalCFGBasePtr() != 0 and not use_vpi:
168:             return self.xcfg.GetSignalNames(prefix)
169:         else:
170:             return self.dut.VPIInternalSignalList(prefix, deep)
171: 
172:     def VPIInternalSignalList(self, prefix="", deep=99):
173:         return self.dut.VPIInternalSignalList(prefix, deep)
174: 
175:     def Finish(self):
176:         self.dut.Finish()
177: 
178:     def RefreshComb(self):
179:         self.dut.RefreshComb()
180: 
181:     def AtClone(self):
182:         """Re-init simulator state in child after fork."""
183:         return self.dut.atClone()
184: 
185:     ################################
186:     #      End of User APIs        #
187:     ################################
188: 
189:     def __getitem__(self, key):
190:         return xsp.XPin(self.port[key], self.event)
191: 
192:     # Async APIs wrapped from XClock
193:     async def AStep(self,i: int):
194:         return await self.xclock.AStep(i)
195: 
196:     async def ACondition(self,fc_cheker):
197:         return await self.xclock.ACondition(fc_cheker)
198: 
199:     def RunStep(self,i: int):
200:         return self.xclock.RunStep(i)
201: 
202:     def __setattr__(self, name, value):
203:         assert not isinstance(getattr(self, name, None),
204:                               (xsp.XPin, xsp.XData)), \
205:         f"XPin and XData of DUT are read-only, do you mean to set the value of the signal? please use `{name}.value = ` instead."
206:         return super().__setattr__(name, value)
207: 
208: 
209: if __name__=="__main__":
210:     dut=DUTCaseFixed()
211:     dut.Step(100)

