 29:             self.dut.SetWaveform(kwargs.get("waveform_filename"))
 30:         if kwargs.get("coverage_filename"):
 31:             self.dut.SetCoverage(kwargs.get("coverage_filename"))
 32: 
 33:         # All pins
 34:         self.normal_req_pending = xsp.XPin(xsp.XData(0, xsp.XData.In), self.event)
 35:         self.prefetch_valid = xsp.XPin(xsp.XData(0, xsp.XData.In), self.event)
 36:         self.prefetch_addr = xsp.XPin(xsp.XData(32, xsp.XData.In), self.event)
 37:         self.explicit_flush = xsp.XPin(xsp.XData(0, xsp.XData.In), self.event)
 38:         self.stage_flush = xsp.XPin(xsp.XData(0, xsp.XData.Out), self.event)
 39:         self.prefetch_out_valid = xsp.XPin(xsp.XData(0, xsp.XData.Out), self.event)
 40: 
 41: 
 42:         # BindDPI or Native pin address
 43:         self.normal_req_pending.BindDPIPtr(self.dut.GetDPIHandle("normal_req_pending", 0), self.dut.GetDPIHandle("normal_req_pending", 1))
 44:         self.prefetch_valid.BindDPIPtr(self.dut.GetDPIHandle("prefetch_valid", 0), self.dut.GetDPIHandle("prefetch_valid", 1))
 45:         self.prefetch_addr.BindDPIPtr(self.dut.GetDPIHandle("prefetch_addr", 0), self.dut.GetDPIHandle("prefetch_addr", 1))
 46:         self.explicit_flush.BindDPIPtr(self.dut.GetDPIHandle("explicit_flush", 0), self.dut.GetDPIHandle("explicit_flush", 1))
 47:         self.stage_flush.BindDPIPtr(self.dut.GetDPIHandle("stage_flush", 0), self.dut.GetDPIHandle("stage_flush", 1))
 48:         self.prefetch_out_valid.BindDPIPtr(self.dut.GetDPIHandle("prefetch_out_valid", 0), self.dut.GetDPIHandle("prefetch_out_valid", 1))
 49: 
 50: 
 51:         # Add2Port
 52:         self.xport.Add("normal_req_pending", self.normal_req_pending.xdata)
 53:         self.xport.Add("prefetch_valid", self.prefetch_valid.xdata)
 54:         self.xport.Add("prefetch_addr", self.prefetch_addr.xdata)
 55:         self.xport.Add("explicit_flush", self.explicit_flush.xdata)
 56:         self.xport.Add("stage_flush", self.stage_flush.xdata)
 57:         self.xport.Add("prefetch_out_valid", self.prefetch_out_valid.xdata)
 58: 
 59: 
 60:         # Cascaded ports
 61:         self.prefetch = self.xport.NewSubPort("prefetch_")
 62: 
