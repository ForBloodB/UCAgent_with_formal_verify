 1: from dataclasses import dataclass
 2: 
 3: 
 4: MMIO_PREFIX = 0xF
 5: 
 6: 
 7: @dataclass(frozen=True)
 8: class PrefetchMmioResult:
 9:     stage_flush: bool
10:     prefetch_out_valid: bool
11:     normal_request_survived: bool
12: 
13: 
14: class PrefetchMmioCase:
15:     def __init__(self, variant: str):
16:         if variant not in {"buggy", "fixed"}:
17:             raise ValueError(f"unknown variant: {variant}")
18:         self.variant = variant
19: 
20:     def step(
21:         self,
22:         normal_req_pending: bool,
23:         prefetch_valid: bool,
24:         prefetch_addr: int,
25:         explicit_flush: bool,
26:     ) -> PrefetchMmioResult:
27:         prefetch_is_mmio = ((prefetch_addr >> 28) & 0xF) == MMIO_PREFIX
28: 
29:         if self.variant == "buggy":
30:             stage_flush = explicit_flush or (prefetch_valid and prefetch_is_mmio)
31:             prefetch_out_valid = prefetch_valid
32:         else:
33:             stage_flush = explicit_flush
34:             prefetch_out_valid = prefetch_valid and not prefetch_is_mmio
35: 
36:         normal_request_survived = bool(normal_req_pending and not stage_flush)
37:         return PrefetchMmioResult(
38:             stage_flush=bool(stage_flush),
39:             prefetch_out_valid=bool(prefetch_out_valid),
40:             normal_request_survived=normal_request_survived,
41:         )

