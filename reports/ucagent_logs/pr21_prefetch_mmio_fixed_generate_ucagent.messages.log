198: 
199:     def RunStep(self,i: int):
200:         return self.xclock.RunStep(i)
201: 
202:     def __setattr__(self, name, value):
203:         assert not isinstance(getattr(self, name, None),
204:                               (xsp.XPin, xsp.XData)), \
205:         f"XPin and XData of DUT are read-only, do you mean to set the value of the signal? please use `{name}.value = ` instead."
206:         return super().__setattr__(name, value)
