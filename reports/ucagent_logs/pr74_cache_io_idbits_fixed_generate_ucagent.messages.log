    new_string: def test_nonzero_request_id_preserved(env):
    """测试单个非零请求ID的保真度

    验证对于任意非零的req_id，resp_id必须等于req_id。
    使用README中指定的req_id=0xA作为主要测试数据，
    同时额外覆盖0x5（另一个非零值）避免单常量测试。

    Args:
        env: Env fixture实例，由pytest自动注入
    """
    env.dut.fc_cover["FG-API"].mark_function(
        "FC-ID_ROUNDTRIP",
        test_nonzero_request_id_preserved,
        ["CK-NONZERO_ID_PRESERVED"],
    )

    # 典型值：使用README中指定的0xA作为主要测试数据
    test_ids = [0xA, 0x5]

    for rid in test_ids:
        resp = api_CaseFixed_id_roundtrip(env, rid)
        assert resp == rid, (
            f"非零请求ID保真失败: req_id=0x{rid:X}, "
            f"期望resp_id=0x{rid:X}, 实际resp_id=0x{resp:X}"
        )

    # 边界值：测试全范围非零边界
    boundary_ids = [0x1, 0xF]
    for rid in boundary_ids:
        resp = api_CaseFixed_id_roundtrip(env, rid)
        assert resp == rid, (
            f"边界请求ID保真失败: req_id=0x{rid:X}, "
            f"期望resp_id=0x{rid:X}, 实际resp_id=0x{resp:X}"
        )


def test_multiple_request_ids_preserved(env):
