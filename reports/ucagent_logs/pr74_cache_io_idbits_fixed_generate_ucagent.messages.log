from CaseFixed_api import *
from CaseFixed import DUTCaseFixed
from CaseFixed_function_coverage_def import get_coverage_groups
import pytest


def test_nonzero_request_id_preserved():
    """测试非零请求ID是否被正确保留在响应中

    验证对于非零的req_id，resp_id必须等于req_id。
    使用req_id=0xA（来自PR #74的典型场景）作为测试数据。
    """
    dut = DUTCaseFixed()
    groups = get_coverage_groups(dut)
    dut.StepRis(lambda _: [g.sample() for g in groups])
    fc_cover = {g.name: g for g in groups}
    ev = CaseFixedEnv(dut)

    fc_cover["FG-API"].mark_function(
        "FC-ID_ROUNDTRIP",
        test_nonzero_request_id_preserved,
        ["CK-NONZERO_ID_PRESERVED"],
    )

    req_id = 0xA  # 非零请求ID（典型值）
    resp_id = api_CaseFixed_id_roundtrip(ev, req_id)
    assert resp_id == req_id, (
        f"非零请求ID未被正确保留：req_id=0x{req_id:X}，"
        f"resp_id=0x{resp_id:X}，期望resp_id=0x{req_id:X}"
    )

    dut.Finish()


def test_multiple_request_ids_preserved():
    """测试多个不同的非零请求ID都能被正确保留在响应中

    覆盖多种非零ID值（典型值、边界值、特殊值），确保resp_id == req_id。
    包含：最小值（0x1）、典型值（0x5, 0x9, 0xA）、最大值（0xF）。
    """
    dut = DUTCaseFixed()
    groups = get_coverage_groups(dut)
    dut.StepRis(lambda _: [g.sample() for g in groups])
    fc_cover = {g.name: g for g in groups}
    ev = CaseFixedEnv(dut)

    fc_cover["FG-API"].mark_function(
        "FC-ID_ROUNDTRIP",
        test_multiple_request_ids_preserved,
        ["CK-MULTIPLE_ID_VALUES"],
    )

    test_ids = [0x1, 0x5, 0x9, 0xA, 0xF]  # 覆盖典型值、边界值和特殊值

    for req_id in test_ids:
        resp_id = api_CaseFixed_id_roundtrip(ev, req_id)
        assert resp_id == req_id, (
            f"请求ID 0x{req_id:X} 未被正确保留："
            f"resp_id=0x{resp_id:X}，期望resp_id=0x{req_id:X}"
        )

    dut.Finish()

