 52:         self.Finish()
 53: 
 54:     ################################
 55:     #         User APIs            #
 56:     ################################
 57:     def InitClock(self, name: str):
 58:         self.xclock.Add(self.xport[name])
 59: 
 60:     def Step(self, i:int = 1):
 61:         self.xclock.Step(i)
 62: 
 63:     def StepRis(self, callback, args=(), kwargs={}):
 64:         self.xclock.StepRis(callback, args, kwargs)
 65: 
 66:     def StepFal(self, callback, args=(), kwargs={}):
 67:         self.xclock.StepFal(callback, args, kwargs)
 68: 
 69:     def ResumeWaveformDump(self):
 70:         return self.dut.ResumeWaveformDump()
 71: 
 72:     def PauseWaveformDump(self):
 73:         return self.dut.PauseWaveformDump()
 74: 
 75:     def WaveformPaused(self) -> int:
 76:         """ Returns 1 if waveform export is paused """
 77:         return self.dut.WaveformPaused()
 78: 
 79:     def GetXPort(self):
 80:         return self.xport
 81: 
 82:     def GetXClock(self):
 83:         return self.xclock
 84: 
 85:     def SetWaveform(self, filename: str):
 86:         self.dut.SetWaveform(filename)
 87: 
 88:     def GetWaveFormat(self) -> str:
 89:         """
 90:         Get the waveform extension, or an empty string if disabled.
 91: 
 92:         Returns:
 93:             str: The extension of waveform file.
 94:         """
 95:         return self.dut.GetWaveFormat()
 96: 
 97:     def FlushWaveform(self):
 98:         self.dut.FlushWaveform()
 99: 
100:     def SetCoverage(self, filename: str):
101:         self.dut.SetCoverage(filename)
102: 
103:     def GetCovMetrics(self) -> int:
104:         """
105:         Get the bitmask for collected coverage metrics. 0 means coverage is disabled
106: 
107:         Returns:
108:             int: Collected coverage metrics bitmask:
109:                 - Bit 0: line   (Line coverage)
110:                 - Bit 1: cond   (Condition coverage)
111:                 - Bit 2: fsm    (Finite-State Machine coverage)
112:                 - Bit 3: toggle (Toggle coverage)
113:                 - Bit 4: branch (Branch coverage)
114:                 - Bit 5: assert (Assertion coverage)
115:         """
116:         return self.dut.GetCovMetrics()
117:     
118:     def CheckPoint(self, name: str) -> int:
119:         self.dut.CheckPoint(name)
120: 
121:     def Restore(self, name: str) -> int:
122:         self.dut.Restore(name)
123: 
124:     def GetInternalSignal(self, name: str, index=-1, is_array=False, use_vpi=False):
125:         if name not in self.internal_signals:
126:             signal = None
127:             if self.dut.GetXSignalCFGBasePtr() != 0 and not use_vpi:
128:                 xname = "CFG:" + name
129:                 if is_array:
130:                     assert index < 0, "Index is not supported for array signal"
131:                     signal = self.xcfg.NewXDataArray(name, xname)
132:                 elif index >= 0:
133:                     signal = self.xcfg.NewXData(name, index, xname)
134:                 else:
135:                     signal = self.xcfg.NewXData(name, xname)
136:             else:
137:                 assert index < 0, "Index is not supported for VPI signal"
138:                 assert not is_array, "Array is not supported for VPI signal"
139:                 signal = xsp.XData.FromVPI(self.dut.GetVPIHandleObj(name),
140:                                            self.dut.GetVPIFuncPtr("vpi_get"),
141:                                            self.dut.GetVPIFuncPtr("vpi_get_value"),
142:                                            self.dut.GetVPIFuncPtr("vpi_put_value"), "VPI:" + name)
143:                 if use_vpi:
144:                     assert signal is not None, f"Internal signal {name} not found (Check VPI is enabled)"
145:             if signal is None:
146:                 return None
147:             if not isinstance(signal, xsp.XData):
148:                 self.internal_signals[name] = [xsp.XPin(s, self.event) for s in signal]
149:             else:
150:                 self.internal_signals[name] = xsp.XPin(signal, self.event)
151:         return self.internal_signals[name]
152: 
153:     def GetInternalSignalList(self, prefix="", deep=99, use_vpi=False):
154:         if self.dut.GetXSignalCFGBasePtr() != 0 and not use_vpi:
155:             return self.xcfg.GetSignalNames(prefix)
156:         else:
157:             return self.dut.VPIInternalSignalList(prefix, deep)
158: 
159:     def VPIInternalSignalList(self, prefix="", deep=99):
160:         return self.dut.VPIInternalSignalList(prefix, deep)
161: 
162:     def Finish(self):
163:         self.dut.Finish()
164: 
165:     def RefreshComb(self):
166:         self.dut.RefreshComb()
167: 
168:     def AtClone(self):
169:         """Re-init simulator state in child after fork."""
170:         return self.dut.atClone()
171: 
172:     ################################
173:     #      End of User APIs        #
174:     ################################
175: 
176:     def __getitem__(self, key):
177:         return xsp.XPin(self.port[key], self.event)
178: 
179:     # Async APIs wrapped from XClock
180:     async def AStep(self,i: int):
181:         return await self.xclock.AStep(i)
182: 
183:     async def ACondition(self,fc_cheker):
184:         return await self.xclock.ACondition(fc_cheker)
185: 
186:     def RunStep(self,i: int):
187:         return self.xclock.RunStep(i)
188: 
189:     def __setattr__(self, name, value):
190:         assert not isinstance(getattr(self, name, None),
191:                               (xsp.XPin, xsp.XData)), \
192:         f"XPin and XData of DUT are read-only, do you mean to set the value of the signal? please use `{name}.value = ` instead."
193:         return super().__setattr__(name, value)
194: 
