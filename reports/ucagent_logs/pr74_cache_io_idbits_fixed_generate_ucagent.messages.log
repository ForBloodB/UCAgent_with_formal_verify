# Test nonzero req_id
print("Setting req_id to 0xA...")
dut.req_id.value = 0xA
print("Stepping...")
dut.Step(1)
print(f"resp_id = {dut.resp_id.value}")
assert dut.resp_id.value == 0xA, f"Expected 0xA, got {dut.resp_id.value}"
print("Test passed!")

dut.Finish()
print("Done!")

