import toffee.funcov as fc


def get_coverage_groups(dut):
    """获取所有功能覆盖组

    Args:
        dut: DUT实例

    Returns:
        List[CovGroup]: 功能覆盖组列表
    """
    group = fc.CovGroup("FG-API")

    # 添加FC-ID_ROUNDTRIP功能点
    # 验证请求ID在响应中不变
    group.add_watch_point(
        dut,
        {
            "CK-NONZERO_ID_PRESERVED": (
                lambda d: int(d.req_id.value) != 0
                and int(d.resp_id.value) == int(d.req_id.value)
            ),
            "CK-MULTIPLE_ID_VALUES": (
                lambda d: int(d.req_id.value) in [0x1, 0x5, 0x9, 0xA, 0xF]
                and int(d.resp_id.value) == int(d.req_id.value)
            ),
        },
        name="FC-ID_ROUNDTRIP",
    )

    return [group]

