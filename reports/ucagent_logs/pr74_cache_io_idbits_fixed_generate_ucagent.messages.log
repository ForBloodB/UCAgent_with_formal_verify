from CaseFixed_api import *
import pytest


def test_nonzero_request_id_preserved(env):
    """测试非零请求ID在响应的保持功能

    验证对于所有非零的req_id值（1~15），resp_id都能正确地与req_id保持一致。
    典型值：1, 2, 7, 8, 15
    边界值：1（最小值非零）, 15（最大值）
    特殊值：5（中间值）

    Args:
        env: Env fixture实例，由pytest自动注入
    """
    env.dut.fc_cover["FG-API"].mark_function(
        "FC-ID_ROUNDTRIP",
        test_nonzero_request_id_preserved,
        ["CK-NONZERO_ID_PRESERVED"],
    )

    # 测试数据：典型值、边界值、特殊值
    test_ids = [
        1,      # 边界值：最小的非零ID
        2,      # 典型值
        5,      # 典型值
        7,      # 典型值
        8,      # 典型值
        15,     # 边界值：最大的4位ID值
    ]

    for req_id in test_ids:
        # 通过API接口调用芯片功能，设置req_id并获取resp_id
        resp_id = api_CaseFixed_id_roundtrip(env, req_id)

        # 断言：resp_id必须等于req_id
        assert resp_id == req_id, (
            f"非零请求ID保持失败: req_id={req_id}, "
            f"期望resp_id={req_id}, 实际resp_id={resp_id}"
        )


def test_multiple_request_ids_preserved(env):
    """测试多个不同请求ID在响应中的保持功能

    验证多个不同的非零req_id值（涵盖典型值、边界值、特殊值），
    每个请求的resp_id都必须正确等于其对应的req_id，
    确保不是由于某些常数巧合导致的假阳性结果。

    Args:
        env: Env fixture实例，由pytest自动注入
    """
    env.dut.fc_cover["FG-API"].mark_function(
        "FC-ID_ROUNDTRIP",
        test_multiple_request_ids_preserved,
        ["CK-MULTIPLE_ID_VALUES"],
    )

    # 测试数据：多个不同的非零ID值
    # 涵盖各种位模式：全1、交替位、单bit置位等
    test_ids = [
        0x1,    # 边界值：最低比特置位
        0x2,    # 典型值：单比特
        0x3,    # 典型值：连续比特
        0x5,    # 特殊值：交替位模式 0101
        0x7,    # 典型值：低三位全1
        0x8,    # 边界值：最高比特置位
        0x9,    # 特殊值：1001 模式
        0xA,    # 特殊值：1010 模式
        0xF,    # 边界值：全1（最大值）
    ]

    for req_id in test_ids:
        # 通过API接口调用芯片功能
        resp_id = api_CaseFixed_id_roundtrip(env, req_id)

        # 断言：resp_id必须等于req_id
        assert resp_id == req_id, (
            f"多ID保持测试失败: req_id={req_id} (0x{req_id:X}), "
            f"期望resp_id={req_id} (0x{req_id:X}), "
            f"实际resp_id={resp_id} (0x{resp_id:X})"
        )

