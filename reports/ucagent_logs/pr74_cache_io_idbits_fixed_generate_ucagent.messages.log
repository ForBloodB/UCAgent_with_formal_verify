 8: from CaseFixed_function_coverage_def import get_coverage_groups
 9: from CaseFixed import DUTCaseFixed
10: 
11: 
12: def current_path_file(file_name):
13:     return os.path.join(os.path.dirname(os.path.abspath(__file__)), file_name)
14: 
15: 
16: def get_coverage_data_path(request, new_path: bool):
17:     tc_name = request.node.name if request is not None else "CaseFixed"
18:     return get_file_in_tmp_dir(request, current_path_file("data/"), f"{tc_name}.dat", new_path=new_path)
19: 
20: 
21: def get_waveform_path(request, new_path: bool):
22:     tc_name = request.node.name if request is not None else "CaseFixed"
23:     return get_file_in_tmp_dir(request, current_path_file("data/"), f"{tc_name}.fst", new_path=new_path)
24: 
25: 
26: def create_dut(request):
27:     if ucagent.is_imp_test_template():
28:         return ucagent.get_fake_dut(DUTCaseFixed)
29:     dut = DUTCaseFixed()
30:     dut.SetCoverage(get_coverage_data_path(request, new_path=True))
31:     dut.SetWaveform(get_waveform_path(request, new_path=True))
32:     return dut
33: 
34: 
35: @pytest.fixture(scope="function")
36: def dut(request):
37:     dut = create_dut(request)
38:     groups = get_coverage_groups(dut)
39:     dut.StepRis(lambda _: [g.sample() for g in groups])
40:     setattr(dut, "fc_cover", {g.name: g for g in groups})
41:     yield dut
42:     set_func_coverage(request, groups)
43:     set_line_coverage(request, get_coverage_data_path(request, new_path=False), ignore=current_path_file("CaseFixed.ignore"))
44:     set_user_info("UCAgent", "-")
45:     set_title_info("CaseFixed Test Report")
46:     for group in groups:
47:         group.clear()
48:     dut.Finish()
49: 
50: 
51: class CaseFixedEnv:
52:     def __init__(self, dut):
53:         self.dut = dut
54: 
55:     def Step(self, cycles: int = 1):
56:         return self.dut.Step(cycles)
57: 
58: 
59: @pytest.fixture(scope="function")
60: def env(dut):
61:     return CaseFixedEnv(dut)
62: 
