 14: class DUTCaseFixed(object):
 15: 
 16:     # initialize
 17:     def __init__(self, *args, **kwargs):
 18:         self.dut = DutUnifiedBase(*args)
 19:         self.xclock = xsp.XClock(self.dut.pxcStep, self.dut.pSelf)
 20:         self.xport  = xsp.XPort()
 21:         self.xclock.Add(self.xport)
 22:         self.event = self.xclock.getEvent()
 23:         self.internal_signals = {}
 24:         self.xcfg = xsp.XSignalCFG(self.dut.GetXSignalCFGPath(), self.dut.GetXSignalCFGBasePtr())
 25:         
 26: 
 27:         # set output files
 28:         if kwargs.get("waveform_filename"):
 29:             self.dut.SetWaveform(kwargs.get("waveform_filename"))
 30:         if kwargs.get("coverage_filename"):
 31:             self.dut.SetCoverage(kwargs.get("coverage_filename"))
 32: 
 33:         # All pins
 34:         self.req_id = xsp.XPin(xsp.XData(4, xsp.XData.In), self.event)
 35:         self.resp_id = xsp.XPin(xsp.XData(4, xsp.XData.Out), self.event)
 36: 
 37: 
 38:         # BindDPI or Native pin address
 39:         self.req_id.BindDPIPtr(self.dut.GetDPIHandle("req_id", 0), self.dut.GetDPIHandle("req_id", 1))
 40:         self.resp_id.BindDPIPtr(self.dut.GetDPIHandle("resp_id", 0), self.dut.GetDPIHandle("resp_id", 1))
 41: 
 42: 
 43:         # Add2Port
 44:         self.xport.Add("req_id", self.req_id.xdata)
 45:         self.xport.Add("resp_id", self.resp_id.xdata)
 46: 
 47: 
 48:         # Cascaded ports
 49: 
 50: 
