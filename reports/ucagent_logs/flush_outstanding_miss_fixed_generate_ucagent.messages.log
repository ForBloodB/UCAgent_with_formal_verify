 14: class DUTCaseFixed(object):
 15: 
 16:     # initialize
 17:     def __init__(self, *args, **kwargs):
 18:         self.dut = DutUnifiedBase(*args)
 19:         self.xclock = xsp.XClock(self.dut.pxcStep, self.dut.pSelf)
 20:         self.xport  = xsp.XPort()
 21:         self.xclock.Add(self.xport)
 22:         self.event = self.xclock.getEvent()
 23:         self.internal_signals = {}
 24:         self.xcfg = xsp.XSignalCFG(self.dut.GetXSignalCFGPath(), self.dut.GetXSignalCFGBasePtr())
 25:         
 26: 
 27:         # set output files
 28:         if kwargs.get("waveform_filename"):
 29:             self.dut.SetWaveform(kwargs.get("waveform_filename"))
 30:         if kwargs.get("coverage_filename"):
 31:             self.dut.SetCoverage(kwargs.get("coverage_filename"))
 32: 
 33:         # All pins
 34:         self.miss_outstanding = xsp.XPin(xsp.XData(0, xsp.XData.In), self.event)
 35:         self.flush_valid = xsp.XPin(xsp.XData(0, xsp.XData.In), self.event)
 36:         self.mem_resp_valid = xsp.XPin(xsp.XData(0, xsp.XData.In), self.event)
 37:         self.cpu_resp_valid = xsp.XPin(xsp.XData(0, xsp.XData.Out), self.event)
 38: 
 39: 
 40:         # BindDPI or Native pin address
 41:         self.miss_outstanding.BindDPIPtr(self.dut.GetDPIHandle("miss_outstanding", 0), self.dut.GetDPIHandle("miss_outstanding", 1))
 42:         self.flush_valid.BindDPIPtr(self.dut.GetDPIHandle("flush_valid", 0), self.dut.GetDPIHandle("flush_valid", 1))
 43:         self.mem_resp_valid.BindDPIPtr(self.dut.GetDPIHandle("mem_resp_valid", 0), self.dut.GetDPIHandle("mem_resp_valid", 1))
 44:         self.cpu_resp_valid.BindDPIPtr(self.dut.GetDPIHandle("cpu_resp_valid", 0), self.dut.GetDPIHandle("cpu_resp_valid", 1))
 45: 
 46: 
 47:         # Add2Port
 48:         self.xport.Add("miss_outstanding", self.miss_outstanding.xdata)
